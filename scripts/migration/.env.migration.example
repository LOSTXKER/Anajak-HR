# ===========================================
# Supabase Region Migration - Configuration
# ===========================================
# Copy this file to .env.migration and fill in the values
# cp .env.migration.example .env.migration

# -------------------------------------------
# Old Supabase Project (source)
# -------------------------------------------
# Find these at: Supabase Dashboard > Project > Settings > API
OLD_SUPABASE_URL=https://xxxxx.supabase.co
OLD_SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Find at: Settings > Database > Connection string > URI (select "Direct connection")
# Format: postgresql://postgres.[ref]:[password]@db.[ref].supabase.co:5432/postgres
OLD_DB_URL=postgresql://postgres.xxxxx:YOUR_DB_PASSWORD@db.xxxxx.supabase.co:5432/postgres

# -------------------------------------------
# New Supabase Project (destination - Singapore)
# -------------------------------------------
NEW_SUPABASE_URL=https://yyyyy.supabase.co
NEW_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
NEW_SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Find at: Settings > Database > Connection string > URI (select "Direct connection")
NEW_DB_URL=postgresql://postgres.yyyyy:YOUR_DB_PASSWORD@db.yyyyy.supabase.co:5432/postgres
